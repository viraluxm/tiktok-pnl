{
  "manifest_version": 3,
  "name": "Lensed — TikTok LIVE Capture",
  "version": "0.2.21",
  "description": "Captures TikTok LIVE auction sales for Lensed analytics.",
  "key": "",
  "minimum_chrome_version": "114",
  "permissions": ["storage"],
  "host_permissions": [
    "https://shop.tiktok.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://*.lensed.io/*",
      "https://lensed.io/*",
      "http://localhost:3000/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://shop.tiktok.com/*"],
      "js": ["tiktok-inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://shop.tiktok.com/*"],
      "js": ["tiktok-content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Lensed — TikTok LIVE Capture",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
